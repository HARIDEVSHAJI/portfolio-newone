# ─── Database (Supabase PostgreSQL for deployment) ─────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
# Use the "Transaction" pooler URL for Vercel (port 6543):
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Also add direct URL for Prisma migrations:
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Supabase Storage (for file uploads on Vercel) ────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-super-secret-32-char-string-here"
# For local dev:
NEXTAUTH_URL="http://localhost:3000"
# For Vercel (set this in Vercel dashboard too):
# NEXTAUTH_URL="https://your-app.vercel.app"

# ─── Admin Credentials ─────────────────────────────────────────────────────
ADMIN_EMAIL="admin@haridev.dev"
ADMIN_PASSWORD="Admin@1234"

# ─── Gmail SMTP (contact form emails) ─────────────────────────────────────
# Enable 2FA → https://myaccount.google.com/apppasswords → Create App Password
GMAIL_USER="haridevshaji@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
